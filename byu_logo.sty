%% ================================================================
%% BYU logo from letters
%% ================================================================

%% Keys
\tikzset{
    byu color/.store in = \byuColor, byu color = byuNavy,
}

\tikzset{ pics/byu_logo/.style = { code = {
    % \input{tl_logo_byu_letters}
    \drawTlByuLetters
}}}

%% ================================================================
%% Cached rendering (render once, stamp many times)
%% ================================================================
\newsavebox{\byuLogoBox}

%% \cacheBYULogo[tikz keys]
%%   Renders byu_logo once into a savebox.  Use \usebox{\byuLogoBox}
%%   everywhere the logo is needed (headers, footers, title pages, etc.).
%%
%% Example (consumer document, after \begin{document}):
%%   \cacheBYULogo[byu color=white, scale=0.4]
%%   ...
%%   \usebox{\byuLogoBox}
\newcommand{\cacheBYULogo}[1][]{%
    \sbox{\byuLogoBox}{%
        \begin{tikzpicture}
            \pic [#1] {byu_logo};
        \end{tikzpicture}%
    }%
}
